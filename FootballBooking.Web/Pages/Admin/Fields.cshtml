@page
@model FootballBooking.Web.Pages.Admin.FieldsModel
@using FootballBooking.Models
@{
    ViewData["Title"] = "Quản lý sân";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0">Quản lý sân bóng</h1>
                <p class="text-muted mb-0">Cập nhật giá và trạng thái sân.</p>
            </div>
            <div class="btn-group" role="group">
                <a href="/Admin/Dashboard" class="btn btn-outline-info">Dashboard</a>
                <a href="/" class="btn btn-outline-secondary">Trang chủ</a>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tên sân</th>
                            <th>Vị trí</th>
                            <th>Giá/giờ</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var field in Model.Fields)
                        {
                            <tr>
                                <td>@field.Id</td>
                                <td>@field.Name</td>
                                <td>@field.Location</td>
                                <td>
                                    <form method="post" class="d-flex align-items-center gap-2">
                                        <input type="hidden" name="FieldId" value="@field.Id" />
                                        <input type="number" step="0.01" class="form-control form-control-sm" name="PricePerHour" value="@field.PricePerHour" />
                                        <button type="submit" class="btn btn-sm btn-primary">Lưu</button>
                                    </form>
                                </td>
                                <td>
                                    <span class="badge @(field.Status == FieldStatus.Active ? "bg-success" : "bg-secondary")">@field.Status</span>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-info" onclick="window.location.href='/Admin/Inventory'">Kho</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
