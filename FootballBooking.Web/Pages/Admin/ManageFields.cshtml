@page
@model FootballBooking.Web.Pages.Admin.ManageFieldsModel
@using FootballBooking.Models
@using FootballBooking.Web.ViewModels
@using System.Text.Encodings.Web
@{
    ViewData["Title"] = "Quản lý sân bóng";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0">Quản lý sân bóng</h1>
                <p class="text-muted mb-0">Xem, thêm, chỉnh sửa, xóa sân bóng và cấu hình giá theo khung giờ.</p>
            </div>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createFieldModal">
                    <i class="fas fa-plus"></i> Thêm sân
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Ảnh</th>
                            <th>Tên sân</th>
                            <th>Vị trí</th>
                            <th>Giá/giờ</th>
                            <th>Khung giờ tăng giá</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var field in Model.Fields)
                        {
                            <tr>
                                <td>@field.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(field.Image))
                                    {
                                        <img src="@field.Image" alt="@field.Name" style="width:80px;height:50px;object-fit:cover;border-radius:8px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có</span>
                                    }
                                </td>
                                <td>@field.Name</td>
                                <td>@field.Location</td>
                                <td>@field.PricePerHour.ToString("N0") VNĐ</td>
                                <td>
                                    @if (field.PeakStartTime.HasValue && field.PeakEndTime.HasValue && field.PeakPricePerHour.HasValue)
                                    {
                                        <span>@field.PeakStartTime.Value.ToString(@"hh\:mm") - @field.PeakEndTime.Value.ToString(@"hh\:mm")</span>
                                        <br />
                                        <small class="text-muted">@field.PeakPricePerHour.Value.ToString("N0") VNĐ/giờ</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa cấu hình</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(field.Status == FieldStatus.Active ? "bg-success" : "bg-secondary")">@field.Status</span>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editFieldModal"
                                                onclick="editField(@field.Id, '@JavaScriptEncoder.Default.Encode(field.Name)', '@JavaScriptEncoder.Default.Encode(field.Location)', @field.PricePerHour.ToString(System.Globalization.CultureInfo.InvariantCulture), '@field.Status', '@(field.PeakStartTime?.ToString(@"hh\:mm") ?? "")', '@(field.PeakEndTime?.ToString(@"hh\:mm") ?? "")', '@(field.PeakPricePerHour?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")')">
                                            <i class="fas fa-edit"></i> Sửa
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteFieldModal"
                                                onclick="deleteField(@field.Id, '@JavaScriptEncoder.Default.Encode(field.Name)')">
                                            <i class="fas fa-trash"></i> Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createFieldModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" accept-charset="utf-8" enctype="multipart/form-data" asp-page-handler="CreateField">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm sân bóng mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tên sân</label>
                        <input type="text" class="form-control" name="Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vị trí</label>
                        <input type="text" class="form-control" name="Location" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Giá thường/giờ (VNĐ)</label>
                        <input type="number" step="1000" class="form-control" name="PricePerHour" required />
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Bắt đầu tăng giá</label>
                            <input type="time" class="form-control" name="PeakStartTime" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Kết thúc tăng giá</label>
                            <input type="time" class="form-control" name="PeakEndTime" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Giá tăng/giờ (VNĐ)</label>
                            <input type="number" step="1000" class="form-control" name="PeakPricePerHour" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ảnh sân</label>
                        <input type="file" class="form-control" name="ImageFile" accept="image/*" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-select" name="Status">
                            <option value="Active">Hoạt động</option>
                            <option value="Inactive">Không hoạt động</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Tạo</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editFieldModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" accept-charset="utf-8" enctype="multipart/form-data" asp-page-handler="UpdateField">
                <input type="hidden" name="FieldId" id="editFieldId" />
                <div class="modal-header">
                    <h5 class="modal-title">Chỉnh sửa sân bóng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tên sân</label>
                        <input type="text" class="form-control" name="Name" id="editName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vị trí</label>
                        <input type="text" class="form-control" name="Location" id="editLocation" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Giá thường/giờ (VNĐ)</label>
                        <input type="number" step="1000" class="form-control" name="PricePerHour" id="editPricePerHour" required />
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Bắt đầu tăng giá</label>
                            <input type="time" class="form-control" name="PeakStartTime" id="editPeakStartTime" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Kết thúc tăng giá</label>
                            <input type="time" class="form-control" name="PeakEndTime" id="editPeakEndTime" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Giá tăng/giờ (VNĐ)</label>
                            <input type="number" step="1000" class="form-control" name="PeakPricePerHour" id="editPeakPricePerHour" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ảnh sân (nếu muốn thay đổi)</label>
                        <input type="file" class="form-control" name="ImageFile" accept="image/*" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-select" name="Status" id="editStatus">
                            <option value="Active">Hoạt động</option>
                            <option value="Inactive">Không hoạt động</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteFieldModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="DeleteField">
                <input type="hidden" name="FieldId" id="deleteFieldId" />
                <div class="modal-header">
                    <h5 class="modal-title">Xác nhận xóa</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn có chắc chắn muốn xóa sân bóng <strong id="deleteFieldName"></strong>?</p>
                    <p class="text-danger">Hành động này không thể hoàn tác.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function editField(id, name, location, pricePerHour, status, peakStartTime, peakEndTime, peakPricePerHour) {
        document.getElementById('editFieldId').value = id;
        document.getElementById('editName').value = name;
        document.getElementById('editLocation').value = location;
        document.getElementById('editPricePerHour').value = pricePerHour;
        document.getElementById('editStatus').value = status;
        document.getElementById('editPeakStartTime').value = peakStartTime;
        document.getElementById('editPeakEndTime').value = peakEndTime;
        document.getElementById('editPeakPricePerHour').value = peakPricePerHour;
    }

    function deleteField(id, name) {
        document.getElementById('deleteFieldId').value = id;
        document.getElementById('deleteFieldName').textContent = name;
    }
</script>
