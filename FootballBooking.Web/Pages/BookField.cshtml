@page
@model BookFieldModel
@using System.Text.Json
@{
    ViewData["Title"] = "Đặt sân";
    var fieldsJson = JsonSerializer.Serialize(Model.Fields.Select(field => new
    {
        field.Id,
        field.Name,
        field.Location,
        field.Description,
        field.PricePerHour,
        PeakStartTime = field.PeakStartTime?.ToString(@"hh\:mm"),
        PeakEndTime = field.PeakEndTime?.ToString(@"hh\:mm"),
        field.PeakPricePerHour
    }));
}

<div class="container py-5">
    <h1 class="mb-4">Đặt sân bóng đá</h1>

    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.SuccessMessage != null)
    {
        <div class="alert alert-success">
            @Model.SuccessMessage
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5>Chọn sân và thời gian</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-3">
                            <label for="fieldId" class="form-label">Chọn sân</label>
                            <select class="form-select" id="fieldId" name="FieldId" required>
                                <option value="">-- Chọn sân --</option>
                                @foreach (var field in Model.Fields)
                                {
                                    <option value="@field.Id">@field.Name - @field.Location</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="bookingDate" class="form-label">Ngày đặt</label>
                            <input type="date" class="form-control" id="bookingDate" name="BookingDate"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="startTime" class="form-label">Giờ bắt đầu</label>
                                <select class="form-select" id="startTime" name="StartTime" required>
                                    @for (int hour = 6; hour <= 22; hour++)
                                    {
                                        <option value="@hour:00">@hour:00</option>
                                        <option value="@hour:30">@hour:30</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="endTime" class="form-label">Giờ kết thúc</label>
                                <select class="form-select" id="endTime" name="EndTime" required>
                                    @for (int hour = 7; hour <= 23; hour++)
                                    {
                                        <option value="@hour:00">@hour:00</option>
                                        <option value="@hour:30">@hour:30</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="note" class="form-label">Ghi chú</label>
                            <textarea class="form-control" id="note" name="Note" rows="3"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary">Đặt sân</button>
                        <a href="/" class="btn btn-secondary">Quay lại</a>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Thông tin sân</h5>
                </div>
                <div class="card-body">
                    <div id="fieldInfo">
                        <p class="text-muted">Chọn sân để xem thông tin</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const fields = @Html.Raw(fieldsJson);
    const currencyFormatter = new Intl.NumberFormat('vi-VN');

    function parseTime(value) {
        if (!value) {
            return null;
        }

        const [hours, minutes] = value.split(':').map(Number);
        return hours + minutes / 60;
    }

    function calculatePrice(field, startTime, endTime) {
        const start = parseTime(startTime);
        const end = parseTime(endTime);
        if (!field || start === null || end === null || end <= start) {
            return null;
        }

        const duration = end - start;
        if (!field.PeakStartTime || !field.PeakEndTime || !field.PeakPricePerHour) {
            return duration * field.PricePerHour;
        }

        const peakStart = parseTime(field.PeakStartTime);
        const peakEnd = parseTime(field.PeakEndTime);
        const overlapStart = Math.max(start, peakStart);
        const overlapEnd = Math.min(end, peakEnd);
        const peakHours = overlapEnd > overlapStart ? overlapEnd - overlapStart : 0;
        const normalHours = duration - peakHours;

        return normalHours * field.PricePerHour + peakHours * field.PeakPricePerHour;
    }

    function updateFieldInfo() {
        const fieldId = Number(document.getElementById('fieldId').value);
        const field = fields.find(item => item.Id === fieldId);
        const fieldInfo = document.getElementById('fieldInfo');

        if (!field) {
            fieldInfo.innerHTML = '<p class="text-muted">Chọn sân để xem thông tin</p>';
            return;
        }

        const peakInfo = field.PeakStartTime && field.PeakEndTime && field.PeakPricePerHour
            ? `<p><strong>Giờ tăng giá:</strong> ${field.PeakStartTime} - ${field.PeakEndTime}</p>
               <p><strong>Giá tăng:</strong> ${currencyFormatter.format(field.PeakPricePerHour)} VNĐ/giờ</p>`
            : '<p><strong>Giờ tăng giá:</strong> Chưa cấu hình</p>';

        const estimatedPrice = calculatePrice(
            field,
            document.getElementById('startTime').value,
            document.getElementById('endTime').value);
        const estimateInfo = estimatedPrice === null
            ? '<p class="text-danger">Khung giờ chưa hợp lệ</p>'
            : `<p><strong>Tạm tính:</strong> ${currencyFormatter.format(estimatedPrice)} VNĐ</p>`;

        fieldInfo.innerHTML = `
            <h6>${field.Name}</h6>
            <p><strong>Vị trí:</strong> ${field.Location}</p>
            <p><strong>Giá thường:</strong> ${currencyFormatter.format(field.PricePerHour)} VNĐ/giờ</p>
            ${peakInfo}
            <p><strong>Mô tả:</strong> ${field.Description || 'Không có'}</p>
            ${estimateInfo}
        `;
    }

    document.getElementById('fieldId').addEventListener('change', updateFieldInfo);
    document.getElementById('startTime').addEventListener('change', updateFieldInfo);
    document.getElementById('endTime').addEventListener('change', updateFieldInfo);
</script>
