@page "/Checkout/Details/{orderId:int}"
@model FootballBooking.Web.Pages.Checkout.DetailsModel
@using FootballBooking.Models
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0">Chi tiết đơn hàng</h1>
                <p class="text-muted mb-0">Xem lại thông tin đơn hàng và dịch vụ đã chọn.</p>
            </div>
            <a href="/Account/Profile" class="btn btn-outline-secondary">Quay lại hồ sơ</a>
        </div>
    </div>

    @if (Model.Order == null)
    {
        <div class="alert alert-warning">Đơn hàng không tồn tại hoặc bạn không có quyền truy cập.</div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Mã đơn hàng: #@Model.Order.Id</h5>
                        <p class="text-muted mb-1">Ngày tạo: @Model.Order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="text-muted mb-1">Phương thức thanh toán: @Model.Order.PaymentMethod</p>
                        <p class="text-muted mb-0">Trạng thái: <span class="badge bg-info">@Model.Order.Status</span></p>

                        @if (Model.Order.Status == OrderStatus.Completed)
                        {
                            <div class="mt-3">
                                <a href="/Checkout/ExportInvoice/@Model.Order.Id" class="btn btn-success btn-sm" target="_blank">
                                    <i class="fas fa-download me-1"></i> Xuất hóa đơn PDF
                                </a>
                            </div>
                        }
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0">Dịch vụ trong đơn hàng</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Dịch vụ</th>
                                        <th>Số lượng</th>
                                        <th>Giá đơn vị</th>
                                        <th>Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.OrderItems)
                                    {
                                        var service = Model.Services.FirstOrDefault(s => s.Id == item.ServiceId);
                                        <tr>
                                            <td>@service?.Name ?? "Dịch vụ đã xóa"</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.Price.ToString("C")</td>
                                            <td>@(item.Quantity * item.Price).ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Tổng đơn hàng</h5>
                        <p class="display-6 fw-bold">@Model.Order.TotalAmount.ToString("C")</p>
                        <p class="text-muted">Thanh toán: @Model.Order.PaymentMethod</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
