@page
@using FootballBooking.Models
@model FootballBooking.Web.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container-fluid py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Profile Header -->
            <div class="card shadow mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                            @if (!string.IsNullOrEmpty(Model.CurrentUser?.Avt))
                            {
                                <img src="@Model.CurrentUser.Avt" alt="Avatar" class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="avatar-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border-radius: 50%; font-size: 2rem;">
                                    @if (Model.CurrentUser?.Name?.Length > 0)
                                    {
                                        @Model.CurrentUser.Name[0].ToString().ToUpper()
                                    }
                                    else
                                    {
                                        <i class="fas fa-user"></i>
                                    }
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <h4 class="card-title mb-1">@Model.CurrentUser?.Name</h4>
                            <p class="text-muted mb-1">@Model.CurrentUser?.Email</p>
                            <p class="text-muted mb-0">@Model.CurrentUser?.Phone</p>
                        </div>
                        <div class="col-md-2 text-end">
                            <a href="/Account/EditProfile" class="btn btn-outline-primary">
                                <i class="fas fa-edit me-1"></i>Chỉnh sửa
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Navigation Tabs -->
            <ul class="nav nav-tabs mb-4" id="profileTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="bookings-tab" data-bs-toggle="tab" data-bs-target="#bookings" type="button" role="tab" aria-controls="bookings" aria-selected="true">
                        <i class="fas fa-calendar-alt me-2"></i>Lịch đặt sân
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab" aria-controls="orders" aria-selected="false">
                        <i class="fas fa-shopping-cart me-2"></i>Đơn hàng
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="feedback-tab" data-bs-toggle="tab" data-bs-target="#feedback" type="button" role="tab" aria-controls="feedback" aria-selected="false">
                        <i class="fas fa-star me-2"></i>Đánh giá
                    </button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content" id="profileTabsContent">
                <!-- Bookings Tab -->
                <div class="tab-pane fade show active" id="bookings" role="tabpanel" aria-labelledby="bookings-tab">
                    @if (Model.Bookings.Any())
                    {
                        <!-- Search and Filter Controls -->
                        <div class="card shadow mb-3">
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <input type="text" id="bookingSearch" class="form-control" placeholder="Tìm kiếm theo sân...">
                                    </div>
                                    <div class="col-md-3">
                                        <select id="bookingStatusFilter" class="form-select">
                                            <option value="">Tất cả trạng thái</option>
                                            <option value="Pending">Chờ xác nhận</option>
                                            <option value="Confirmed">Đã xác nhận</option>
                                            <option value="Completed">Hoàn thành</option>
                                            <option value="Cancelled">Đã hủy</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <select id="bookingSort" class="form-select">
                                            <option value="date-desc">Mới nhất trước</option>
                                            <option value="date-asc">Cũ nhất trước</option>
                                            <option value="price-high">Giá cao nhất</option>
                                            <option value="price-low">Giá thấp nhất</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button id="clearFilters" class="btn btn-outline-secondary w-100">Xóa lọc</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">Lịch đặt sân của bạn</h5>
                                <span class="badge bg-primary">@Model.Bookings.Count() đặt sân</span>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Mã đặt sân</th>
                                                <th>Sân bóng</th>
                                                <th>Ngày giờ</th>
                                                <th>Thời lượng</th>
                                                <th>Tổng tiền</th>
                                                <th>Trạng thái</th>
                                                <th>Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody id="bookingsTableBody">
                                            @foreach (var booking in Model.Bookings.OrderByDescending(b => b.BookingDate))
                                            {
                                                <tr class="booking-row" data-field="@Model.GetFieldName(booking.FieldId).ToLower()" data-status="@booking.Status" data-price="@booking.TotalPrice" data-date="@booking.BookingDate.ToString("yyyy-MM-dd")">
                                                    <td>
                                                        <span class="fw-bold text-primary">#@booking.Id</span>
                                                    </td>
                                                    <td>
                                                        <div>
                                                            <div class="fw-bold">@Model.GetFieldName(booking.FieldId)</div>
                                                            <small class="text-muted">@Model.GetFieldLocation(booking.FieldId)</small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div>
                                                            <div class="fw-bold">@booking.BookingDate.ToString("dd/MM/yyyy")</div>
                                                            <small class="text-muted">@booking.StartTime.ToString(@"hh\:mm") - @booking.EndTime.ToString(@"hh\:mm")</small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-light text-dark">@booking.DurationHours giờ</span>
                                                    </td>
                                                    <td>
                                                        <span class="fw-bold text-success">@booking.TotalPrice.ToString("N0") VND</span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-@GetStatusColor(booking.Status)">@GetStatusText(booking.Status)</span>
                                                    </td>
                                                    <td>
                                                        <div class="btn-group" role="group">
                                                            <a href="/Bookings/Details?bookingId=@booking.Id" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                                                <i class="fas fa-eye"></i>
                                                            </a>
                                                            @if (booking.Status == BookingStatus.Completed)
                                                            {
                                                                <a href="/Bookings/ExportInvoice/@booking.Id" class="btn btn-sm btn-outline-success" title="Xuất hóa đơn" target="_blank">
                                                                    <i class="fas fa-download"></i>
                                                                </a>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card shadow">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-calendar-times text-muted" style="font-size: 3rem;"></i>
                                <h5 class="mt-3 text-muted">Chưa có lịch đặt sân</h5>
                                <p class="text-muted">Bạn chưa đặt sân nào. Hãy bắt đầu đặt sân ngay!</p>
                                <a href="/" class="btn btn-primary">Đặt sân ngay</a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Orders Tab -->
                <div class="tab-pane fade" id="orders" role="tabpanel" aria-labelledby="orders-tab">
                    @if (Model.Orders.Any())
                    {
                        <div class="card shadow">
                            <div class="card-header">
                                <h5 class="mb-0">Lịch sử đơn hàng</h5>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Mã đơn</th>
                                                <th>Ngày đặt</th>
                                                <th>Tổng tiền</th>
                                                <th>Thanh toán</th>
                                                <th>Trạng thái</th>
                                                <th>Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var order in Model.Orders)
                                            {
                                                <tr>
                                                    <td>#@order.Id</td>
                                                    <td>@order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td>@order.TotalAmount.ToString("N0") VND</td>
                                                    <td>@order.PaymentMethod</td>
                                                    <td>
                                                        <span class="badge bg-@GetOrderStatusColor(order.Status)">@GetOrderStatusText(order.Status)</span>
                                                    </td>
                                                    <td>
                                                        <a href="/Checkout/Details?orderId=@order.Id" class="btn btn-sm btn-outline-primary">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card shadow">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-shopping-cart text-muted" style="font-size: 3rem;"></i>
                                <h5 class="mt-3 text-muted">Chưa có đơn hàng</h5>
                                <p class="text-muted">Bạn chưa có đơn hàng nào.</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Feedback Tab -->
                <div class="tab-pane fade" id="feedback" role="tabpanel" aria-labelledby="feedback-tab">
                    @if (Model.Feedbacks.Any())
                    {
                        <div class="row">
                            @foreach (var feedback in Model.Feedbacks)
                            {
                                <div class="col-md-6 mb-4">
                                    <div class="card shadow h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="me-3">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        <i class="fas fa-star @(i <= feedback.Rating ? "text-warning" : "text-muted")"></i>
                                                    }
                                                </div>
                                                <small class="text-muted">@feedback.CreatedAt?.ToString("dd/MM/yyyy")</small>
                                            </div>
                                            <p class="card-text">@feedback.Message</p>
                                            @if (!string.IsNullOrEmpty(feedback.FieldName))
                                            {
                                                <small class="text-muted">Sân: @feedback.FieldName</small>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(feedback.ReplyMessage))
                                            {
                                                <hr />
                                                <div class="small text-uppercase text-muted mb-2">Phản hồi từ quản trị</div>
                                                <div class="p-3 rounded border bg-light">
                                                    <p class="mb-1">@feedback.ReplyMessage</p>
                                                    <small class="text-muted">
                                                        @(string.IsNullOrWhiteSpace(feedback.RepliedByName) ? "Admin" : feedback.RepliedByName)
                                                        @if (feedback.RepliedAt.HasValue)
                                                        {
                                                            @: - @feedback.RepliedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                                        }
                                                    </small>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="card shadow">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-star text-muted" style="font-size: 3rem;"></i>
                                <h5 class="mt-3 text-muted">Chưa có đánh giá</h5>
                                <p class="text-muted">Bạn chưa đánh giá sân nào.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@{
    string GetStatusColor(BookingStatus status) => status switch
    {
        BookingStatus.Pending => "warning",
        BookingStatus.Confirmed => "info",
        BookingStatus.InProgress => "primary",
        BookingStatus.Completed => "success",
        BookingStatus.Cancelled => "danger",
        BookingStatus.Expired => "secondary",
        _ => "secondary"
    };

    string GetStatusText(BookingStatus status) => status switch
    {
        BookingStatus.Pending => "Chờ xác nhận",
        BookingStatus.Confirmed => "Đã xác nhận",
        BookingStatus.InProgress => "Đang diễn ra",
        BookingStatus.Completed => "Hoàn thành",
        BookingStatus.Cancelled => "Đã hủy",
        BookingStatus.Expired => "Hết hạn",
        _ => "Không xác định"
    };

    string GetOrderStatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "warning",
        OrderStatus.Confirmed => "info",
        OrderStatus.Processing => "primary",
        OrderStatus.InProgress => "primary",
        OrderStatus.Completed => "success",
        OrderStatus.Cancelled => "danger",
        _ => "secondary"
    };

    string GetOrderStatusText(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "Chờ xử lý",
        OrderStatus.Confirmed => "Đã xác nhận",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.InProgress => "Đang thực hiện",
        OrderStatus.Completed => "Hoàn thành",
        OrderStatus.Cancelled => "Đã hủy",
        _ => "Không xác định"
    };
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('bookingSearch');
            const statusFilter = document.getElementById('bookingStatusFilter');
            const sortSelect = document.getElementById('bookingSort');
            const clearFiltersBtn = document.getElementById('clearFilters');

            function filterAndSortBookings() {
                const searchTerm = searchInput.value.toLowerCase();
                const statusValue = statusFilter.value;
                const sortValue = sortSelect.value;

                const rows = Array.from(document.querySelectorAll('.booking-row'));

                // Filter rows
                rows.forEach(row => {
                    const fieldName = row.dataset.field;
                    const status = row.dataset.status;
                    const matchesSearch = fieldName.includes(searchTerm);
                    const matchesStatus = !statusValue || status === statusValue;

                    if (matchesSearch && matchesStatus) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                // Sort visible rows
                sortBookings(sortValue);
            }

            function sortBookings(sortValue) {
                const tbody = document.getElementById('bookingsTableBody');
                const rows = Array.from(tbody.querySelectorAll('.booking-row:not([style*="display: none"])'));

                rows.sort((a, b) => {
                    const aDate = new Date(a.dataset.date);
                    const bDate = new Date(b.dataset.date);
                    const aPrice = parseFloat(a.dataset.price);
                    const bPrice = parseFloat(b.dataset.price);

                    switch (sortValue) {
                        case 'date-asc':
                            return aDate - bDate;
                        case 'date-desc':
                            return bDate - aDate;
                        case 'price-high':
                            return bPrice - aPrice;
                        case 'price-low':
                            return aPrice - bPrice;
                        default:
                            return bDate - aDate; // Default: newest first
                    }
                });

                // Re-append sorted rows
                rows.forEach(row => tbody.appendChild(row));
            }

            function clearFilters() {
                searchInput.value = '';
                statusFilter.value = '';
                sortSelect.value = 'date-desc';
                filterAndSortBookings();
            }

            // Add event listeners
            searchInput.addEventListener('input', filterAndSortBookings);
            statusFilter.addEventListener('change', filterAndSortBookings);
            sortSelect.addEventListener('change', filterAndSortBookings);
            clearFiltersBtn.addEventListener('click', clearFilters);

            // Initialize
            filterAndSortBookings();
        });

        function viewBookingDetails(bookingId) {
            window.location.href = '/Bookings/Details?bookingId=' + bookingId;
        }

        function viewOrderDetails(orderId) {
            window.location.href = '/Checkout/Details?orderId=' + orderId;
        }

        function activateProfileTabFromHash() {
            const hash = window.location.hash;
            if (!hash) return;

            const tabButton = document.querySelector(`#profileTabs button[data-bs-target="${hash}"]`);
            if (tabButton) {
                const tab = new bootstrap.Tab(tabButton);
                tab.show();
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('bookingSearch');
            const statusFilter = document.getElementById('bookingStatusFilter');
            const sortSelect = document.getElementById('bookingSort');
            const clearFiltersBtn = document.getElementById('clearFilters');

            function filterAndSortBookings() {
                const searchTerm = searchInput.value.toLowerCase();
                const statusValue = statusFilter.value;
                const sortValue = sortSelect.value;

                const rows = Array.from(document.querySelectorAll('.booking-row'));

                // Filter rows
                rows.forEach(row => {
                    const fieldName = row.dataset.field;
                    const status = row.dataset.status;
                    const matchesSearch = fieldName.includes(searchTerm);
                    const matchesStatus = !statusValue || status === statusValue;

                    if (matchesSearch && matchesStatus) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                // Sort visible rows
                sortBookings(sortValue);
            }

            function sortBookings(sortValue) {
                const tbody = document.getElementById('bookingsTableBody');
                const rows = Array.from(tbody.querySelectorAll('.booking-row:not([style*="display: none"])'));

                rows.sort((a, b) => {
                    const aDate = new Date(a.dataset.date);
                    const bDate = new Date(b.dataset.date);
                    const aPrice = parseFloat(a.dataset.price);
                    const bPrice = parseFloat(b.dataset.price);

                    switch (sortValue) {
                        case 'date-asc':
                            return aDate - bDate;
                        case 'date-desc':
                            return bDate - aDate;
                        case 'price-high':
                            return bPrice - aPrice;
                        case 'price-low':
                            return aPrice - bPrice;
                        default:
                            return bDate - aDate; // Default: newest first
                    }
                });

                // Re-append sorted rows
                rows.forEach(row => tbody.appendChild(row));
            }

            function clearFilters() {
                searchInput.value = '';
                statusFilter.value = '';
                sortSelect.value = 'date-desc';
                filterAndSortBookings();
            }

            // Add event listeners
            searchInput.addEventListener('input', filterAndSortBookings);
            statusFilter.addEventListener('change', filterAndSortBookings);
            sortSelect.addEventListener('change', filterAndSortBookings);
            clearFiltersBtn.addEventListener('click', clearFilters);

            // Initialize
            filterAndSortBookings();
            activateProfileTabFromHash();
        });
    </script>
}
