@page "/Account/Orders"
@model FootballBooking.Web.Pages.Account.OrdersModel
@using FootballBooking.Models
@{
    ViewData["Title"] = "Dịch vụ đã mua";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title mb-0">
                        <i class="fas fa-shopping-cart me-2"></i>Dịch vụ đã mua
                    </h4>
                </div>
                <div class="card-body">
                    @if (Model.Orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Mã đơn hàng</th>
                                        <th>Ngày đặt</th>
                                        <th>Tổng tiền</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Orders.OrderByDescending(o => o.CreatedAt))
                                    {
                                        <tr>
                                            <td>@order.Id</td>
                                            <td>@(order.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                            <td>@order.TotalAmount.ToString("N0") VND</td>
                                            <td>
                                                <span class="badge @(order.Status == OrderStatus.Completed ? "bg-success" : order.Status == OrderStatus.Pending ? "bg-warning" : "bg-secondary")">
                                                    @order.Status
                                                </span>
                                            </td>
                                            <td>
                                                <a class="btn btn-sm btn-outline-primary me-2" href="/Checkout/Details/@order.Id">
                                                    <i class="fas fa-eye"></i> Xem
                                                </a>
                                                @if (order.Status == OrderStatus.Completed)
                                                {
                                                    <a class="btn btn-sm btn-outline-success" href="/Checkout/ExportInvoice/@order.Id" target="_blank">
                                                        <i class="fas fa-download me-1"></i>Xuất hóa đơn
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">Chưa có đơn hàng nào</h5>
                            <p class="text-muted">Bạn chưa mua dịch vụ nào. Hãy khám phá các dịch vụ của chúng tôi!</p>
                            <a href="/Services" class="btn btn-primary">
                                <i class="fas fa-search me-2"></i>Khám phá dịch vụ
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Order Details Modal -->
<div class="modal fade" id="orderDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="orderDetailsContent">
                <!-- Order details will be loaded here -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showOrderDetails(orderId) {
            // This would typically make an AJAX call to get order details
            // For now, we'll show a placeholder
            const content = `
                <div class="text-center">
                    <i class="fas fa-info-circle fa-2x text-info mb-3"></i>
                    <p>Chi tiết đơn hàng #${orderId} sẽ được hiển thị ở đây.</p>
                    <p class="text-muted">Tính năng này đang được phát triển.</p>
                </div>
            `;
            document.getElementById('orderDetailsContent').innerHTML = content;
            new bootstrap.Modal(document.getElementById('orderDetailsModal')).show();
        }
    </script>
}