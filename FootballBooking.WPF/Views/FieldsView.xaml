<UserControl x:Class="FootballBooking.WPF.Views.FieldsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FootballBooking.WPF.Views"
             xmlns:vm="clr-namespace:FootballBooking.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Grid Margin="0,0,0,20">
            <TextBlock Text="Danh sách sân bóng" FontSize="24" FontWeight="Bold" Foreground="White"/>
            
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Tag="Tìm kiếm sân bóng..." 
                     Style="{StaticResource ModernTextBox}"
                     Width="300" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Button Content="Làm mới" HorizontalAlignment="Right" 
                    Style="{StaticResource ModernButton}" Padding="15,5"
                    Command="{Binding LoadFieldsCommand}"/>
        </Grid>

        <!-- Fields List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Fields}" SelectedItem="{Binding SelectedField}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" 
                            Width="220" Margin="10" Padding="15">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.3" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Icon/Placeholder -->
                            <Border Width="150" Height="100" Background="#2A2A2A" CornerRadius="8,0,0,8">
                                <Grid>
                                    <TextBlock Text="⚽" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                                    <Image Source="{Binding Image, Converter={StaticResource FieldImageConverter}}" 
                                           Stretch="UniformToFill"/>
                                </Grid>
                            </Border>
                            
                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Type}" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Giá: " Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Text="{Binding PricePerHour, StringFormat={}{0:C}/h}" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>

                            <Border Background="#333333" CornerRadius="4" Padding="8,4" Margin="0,10,0,0" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Status}" FontSize="12" Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Actions & Booking Details -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Ngày đặt sân:" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding BookingDate}" Width="150"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Giờ bắt đầu (H):" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding StartHour}" Width="80">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type x:Int32}">
                                    <x:Int32>5</x:Int32><x:Int32>6</x:Int32><x:Int32>7</x:Int32><x:Int32>8</x:Int32>
                                    <x:Int32>9</x:Int32><x:Int32>10</x:Int32><x:Int32>11</x:Int32><x:Int32>12</x:Int32>
                                    <x:Int32>13</x:Int32><x:Int32>14</x:Int32><x:Int32>15</x:Int32><x:Int32>16</x:Int32>
                                    <x:Int32>17</x:Int32><x:Int32>18</x:Int32><x:Int32>19</x:Int32><x:Int32>20</x:Int32>
                                    <x:Int32>21</x:Int32><x:Int32>22</x:Int32>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Thời lượng (H):" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding Duration}" Width="80">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type x:Int32}">
                                    <x:Int32>1</x:Int32><x:Int32>2</x:Int32><x:Int32>3</x:Int32><x:Int32>4</x:Int32>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="XEM CHI TIẾT" Style="{StaticResource ModernButton}" 
                            Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Foreground="White" Command="{Binding ViewDetailsCommand}" Margin="0,0,10,0"/>
                    <Button Content="ĐẶT SÂN NGAY" Style="{StaticResource ModernButton}" 
                            Background="{StaticResource PrimaryBrush}"
                            Command="{Binding BookFieldCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1" Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Đang tải dữ liệu..." Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
