<UserControl x:Class="FootballBooking.WPF.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FootballBooking.WPF.Views"
             xmlns:vm="clr-namespace:FootballBooking.WPF.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Grid Margin="0,0,0,20">
            <TextBlock Text="Dịch vụ &amp; Sản phẩm" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="Làm mới" HorizontalAlignment="Right" 
                    Style="{StaticResource ModernButton}" Padding="15,5"
                    Command="{Binding LoadServicesCommand}"/>
        </Grid>

        <!-- Services List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Services}" SelectedItem="{Binding SelectedService}"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" 
                            Margin="0,5" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="60" Height="60" Background="#2A2A2A" CornerRadius="8" Margin="0,0,20,0">
                                <Grid>
                                    <TextBlock Text="🥤" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                                    <Image Source="{Binding Image, Converter={StaticResource ServiceImageConverter}}" 
                                           Stretch="UniformToFill"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding Description}" FontSize="14" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Border Background="#E53935" CornerRadius="4" Padding="6,2" Margin="0,0,0,5"
                                        Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding DiscountPercent, StringFormat='-{0}%'}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" 
                                               TextDecorations="Strikethrough" Margin="0,0,10,0"
                                               Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding DiscountedPrice, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                                
                                <TextBlock Text="{Binding Quantity, StringFormat='Còn lại: {0}'}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#333333"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Actions -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Số lượng:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}" Width="60" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Chi tiết" Style="{StaticResource ModernButton}" 
                            Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Foreground="White" Command="{Binding ViewDetailsCommand}" Margin="0,0,10,0"/>
                    <Button Content="THÊM VÀO GIỎ" Style="{StaticResource ModernButton}" 
                            Command="{Binding AddToCartCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1" Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Đang tải dữ liệu..." Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
